# API_KEY: IBM Cloud API key used to authenticate and manage VPC instances (VMs)
API_KEY=<your IBM Cloud API Key>

# IBM_REGION: IBM Cloud region where your VPC instances are deployed (e.g. us-south, us-east, eu-de)
IBM_REGION=us-east-2

# VPC_ID: ID of the VPC where VSIs will be created
# Retrieve with: ibmcloud is vpcs
VPC_ID=<your-vpc-id>

# SUBNET_ID: ID of the subnet for the VSI primary network interface
# Retrieve with: ibmcloud is subnets
SUBNET_ID=<your-subnet-id>

# IMAGE_ID: ID of the OS image to use when creating a VSI
# Retrieve with: ibmcloud is images --visibility public | grep ubuntu
IMAGE_ID=<your-image-id>

# SSH_KEY_ID: (optional) ID of the SSH key to inject into the VSI for access
# Retrieve with: ibmcloud is keys
SSH_KEY_ID=<your-ssh-key-id>

# VSI_PROFILE: VSI profile name defining CPU and RAM (default: bx2-2x8 = 2 vCPU / 8 GB RAM)
# List available profiles with: ibmcloud is instance-profiles
VSI_PROFILE=bx2-2x8
